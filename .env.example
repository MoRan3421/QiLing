# 绮灵 QìLíng 环境配置
# 复制此文件为 .env 并填入实际值

# 服务端口
PORT=3001

# 后台管理密钥（必填）
QILING_ADMIN_SECRET=your-admin-secret-here

# 数据目录
QILING_DATA_DIR=./data

# 模型路径（可选）
QILING_MODEL_PATH=./models/qiling-model.gguf

# 前端地址（CORS）
CLIENT_URL=http://localhost:5173

# Discord 机器人配置
DISCORD_TOKEN=
DISCORD_ADMINS=

# API 邀请码
QILING_PRO_INVITE=pro-2024
QILING_ULTRA_INVITE=ultra-2024