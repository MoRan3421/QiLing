{
  "name": "qiling-ai",
  "version": "3.0.0",
  "type": "module",
  "description": "绮灵 QìLíng — 自研可训练 AI 伙伴，越用越强，专属于你 ✨",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "train": "node server/brain/training/autoTrain.js",
    "eval": "node server/brain/training/evaluate.js",
    "version:bump": "node server/brain/versioning/bumpVersion.js",
    "deploy:oracle": "bash scripts/deploy-oracle.sh",
    "deploy:fly": "fly deploy",
    "deploy:firebase": "npm run build && firebase deploy",
    "deploy:firebase:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:firebase:functions": "firebase deploy --only functions",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node server/db/seed.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "framer-motion": "^11.0.25",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.344.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.3",
    "rehype-raw": "^7.0.0",
    "sharp": "^0.33.2",
    "tailwind-merge": "^2.2.1",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
